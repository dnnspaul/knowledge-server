# Knowledge Server Configuration
# Copy this to .env and fill in your values.
#
# OPTION A — Direct provider credentials (recommended; no proxy needed)
# Set the key(s) for the provider(s) you use. Per-provider credentials take
# precedence over the unified endpoint below.
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
#
# Optional: override the base URL for a provider (e.g. for Azure OpenAI, custom proxy)
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
#
# OPTION B — Unified proxy endpoint (backwards compatible)
# A single endpoint that routes all providers. Use this if you have a proxy
# that serves multiple providers under one URL.
#
# LLM_API_KEY=your-api-key-here
# LLM_BASE_ENDPOINT=https://your-llm-endpoint.example.com
#   Routes by model prefix: anthropic/→/anthropic/v1, google/→/gemini/v1beta, else /openai/v1

# LLM model slots — prefix determines provider and API format:
#   anthropic/... → Anthropic API
#   google/...    → Gemini API
#   openai/...    → OpenAI-compatible API
# LLM_EXTRACTION_MODEL=anthropic/claude-sonnet-4-6    # episode → knowledge extraction
# LLM_MERGE_MODEL=anthropic/claude-haiku-4-5          # near-duplicate merge (cheaper)
# LLM_CONTRADICTION_MODEL=anthropic/claude-sonnet-4-6 # contradiction detection
# LLM_SYNTHESIS_MODEL=anthropic/claude-sonnet-4-6     # cross-session synthesis (defaults to LLM_EXTRACTION_MODEL)

# Embedding model
# All embedding APIs must be OpenAI-compatible (/v1/embeddings).
# Priority: EMBEDDING_BASE_URL → OPENAI_BASE_URL → LLM_BASE_ENDPOINT/openai/v1
#
# Changing EMBEDDING_MODEL triggers automatic re-embedding of all entries on the
# next startup or consolidation run (no manual intervention required).
#
# EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_DIMENSIONS=3072  # truncated dimensions — only for text-embedding-3-* (Matryoshka); omit for all other models
#
# Example: local Ollama embeddings while using a cloud LLM:
# EMBEDDING_BASE_URL=http://localhost:11434/v1
# EMBEDDING_MODEL=nomic-embed-text
# (no EMBEDDING_API_KEY needed — Ollama does not require authentication)

# Server
# KNOWLEDGE_PORT=3179
# KNOWLEDGE_HOST=127.0.0.1
# KNOWLEDGE_ADMIN_TOKEN=your-stable-token-here       # optional; random per-process if unset

# Database paths
# Use $HOME rather than ~ — tilde is not expanded in sourced variable assignments
# KNOWLEDGE_DB_PATH=$HOME/.local/share/knowledge-server/knowledge.db
# OPENCODE_DB_PATH=$HOME/.local/share/opencode/opencode.db

# Multi-user support (shared knowledge DB)
# Set when multiple machines/users write to the same knowledge DB so each user's
# consolidation cursor advances independently. Defaults to the machine hostname.
# Use this in CI, shared Postgres setups, or any environment where hostname is
# not a reliable stable identifier.
# KNOWLEDGE_USER_ID=alice

# Source-specific overrides (auto-detected by default)
# CURSOR_DB_PATH=/path/to/state.vscdb
# CODEX_SESSIONS_DIR=$HOME/.codex/sessions
# VSCODE_DATA_DIR=$HOME/Library/Application Support/Code     # macOS
# VSCODE_DATA_DIR=$HOME/.config/Code                         # Linux

# Disable specific sources (all enabled by default)
# OPENCODE_ENABLED=false
# CLAUDE_ENABLED=false
# CURSOR_ENABLED=false
# CODEX_ENABLED=false
# VSCODE_ENABLED=false

# Decay tuning
# DECAY_ARCHIVE_THRESHOLD=0.15
# DECAY_TOMBSTONE_DAYS=180

# Consolidation tuning
# CONSOLIDATION_CHUNK_SIZE=10
# CONSOLIDATION_MAX_SESSIONS=50
# CONSOLIDATION_MIN_MESSAGES=4
# RECONSOLIDATION_SIMILARITY_THRESHOLD=0.82          # near-duplicate merge cutoff; run `knowledge-server calibrate` to find the right value for your embedding model
# CONTRADICTION_MIN_SIMILARITY=0.4                   # lower bound of contradiction scan band; must be below RECONSOLIDATION_SIMILARITY_THRESHOLD
# CONSOLIDATION_POLL_INTERVAL_MS=1800000             # auto-consolidate every 30 min while running (0 = disabled)
# CONSOLIDATION_INCLUDE_TOOL_OUTPUTS=atlassian_confluence_get_page,atlassian_confluence_search
#   Comma-separated tool names whose completed outputs are included in knowledge extraction.
#   Default: empty (no tool outputs). Add any MCP tool whose output contains knowledge worth encoding.

# Activation tuning
# ACTIVATION_MAX_RESULTS=10
# ACTIVATION_SIMILARITY_THRESHOLD=0.3
